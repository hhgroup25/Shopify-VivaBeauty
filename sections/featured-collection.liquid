{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_display = section.settings.limit
  if collection != blank and collection.all_products_count < products_to_display
    assign products_to_display = collection.all_products_count
  endif

  assign header_layout = section.settings.header_layout
  assign show_all_button_on_top = section.settings.show_all_button_on_top
  assign button_style = section.settings.button_style
  assign button_label = section.settings.button_label
  assign button_link = collection.url

  assign description = section.settings.description
  if section.settings.show_collection_description
    assign description = collection.description
  endif

  assign columns_desktop = section.settings.columns

  assign columns_tablet_large = columns_desktop | at_most: 4

  assign columns_tablet = columns_desktop | minus: 1
  if columns_desktop < 4 or request.design_mode
    assign columns_tablet = columns_desktop
  endif

  assign columns_mobile = section.settings.columns_mobile | plus: 0

  assign enable_swipe_mobile = false
  if section.settings.swipe_on_mobile and products_to_display > columns_mobile
    assign enable_swipe_mobile = true
  endif

  assign item_css_class = 'f-column'

  assign enable_slider = false
  if section.settings.enable_slider and products_to_display > columns_desktop
    assign enable_slider = true
    assign item_css_class = item_css_class | append: ' swiper-slide'
  endif

  assign is_metro = false
  if section.settings.grid_layout == 'metro' and enable_slider == false
    assign is_metro = true
  endif
-%}
{%- if is_metro -%}
  {%- render 'product-grid-metro-style',
    section_id: section.id,
    columns_desktop: columns_desktop,
    columns_tablet_large: columns_tablet_large,
    columns_tablet: columns_tablet,
    columns_mobile: columns_mobile
  -%}
{%- endif -%}
{%- capture image_sizes -%}
(max-width: 767px) calc((100vw - 30px) / {{ columns_mobile }}),
(max-width: 1023px) calc((100vw - 30px) / {{ columns_tablet }}),
{{ settings.page_width | divided_by: columns_desktop }}px
{%- endcapture -%}
{{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}

<style>
  /* ---- AJUSTES DO PARCELAMENTO ---- */
  .section-{{ section.id }} .vb-extra {
    margin-top: 2px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .section-{{ section.id }} .vb-installments {
    display: inline-flex;
    align-items: baseline;
    flex-wrap: nowrap;
    white-space: nowrap;
    font-size: 20.7px;
    font-weight: 600;
    color: #DB2B4E;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .section-{{ section.id }} .vb-installments__big {
    font-size: 1.1em;
    font-weight: 800;
    color: #DB2B4E;
    margin-right: 4px;
    letter-spacing: -0.02em;
  }

  .section-{{ section.id }} .vb-installments__small {
    font-size: 0.72em;
    font-weight: 500 !important;
    color: #DB2B4E;
    white-space: nowrap;
    opacity: 0.95;
  }

  /* ---- AFASTAR BOTÃO DE COMPRA DOS PREÇOS ---- */
  .section-{{ section.id }} .card-product .btn,
  .section-{{ section.id }} .card-product .button,
  .section-{{ section.id }} .product-card .btn,
  .section-{{ section.id }} .product-card .button,
  .section-{{ section.id }} .card__buttons .btn,
  .section-{{ section.id }} .card__buttons .button,
  .section-{{ section.id }} .product-card__actions .btn,
  .section-{{ section.id }} .product-card__actions .button,
  .section-{{ section.id }} form[action*="/cart/add"] .btn,
  .section-{{ section.id }} form[action*="/cart/add"] .button,
  .section-{{ section.id }} form[action*="/cart/add"] button {
    margin-top: 12px !important;
  }

  @media screen and (max-width: 767px) {
    .section-{{ section.id }} .vb-installments {
      font-size: 18.4px;
    }

    .section-{{ section.id }} .vb-installments__big {
      font-size: 1.08em;
    }

    .section-{{ section.id }} .vb-installments__small {
      font-size: 0.74em;
    }

    .section-{{ section.id }} .card-product .btn,
    .section-{{ section.id }} .card-product .button,
    .section-{{ section.id }} .product-card .btn,
    .section-{{ section.id }} .product-card .button,
    .section-{{ section.id }} .card__buttons .btn,
    .section-{{ section.id }} .card__buttons .button,
    .section-{{ section.id }} .product-card__actions .btn,
    .section-{{ section.id }} .product-card__actions .button,
    .section-{{ section.id }} form[action*="/cart/add"] .btn,
    .section-{{ section.id }} form[action*="/cart/add"] .button,
    .section-{{ section.id }} form[action*="/cart/add"] button {
      margin-top: 10px !important;
    }
  }
</style>

{% render 'divider',
  show_divider: section.settings.show_section_divider,
  divider_width: section.settings.divider_width
%}

<div
  class="section section-{{ section.id }}{% if enable_slider %} slider-enabled{% endif %} section--featured-collection section-header-{{ header_layout }} section--padding page-width color-{{ section.settings.color_scheme }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--section-padding-top: {{ section.settings.padding_top }}px;--section-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-id="{{ section.id }}"
>
  <div class="section__wrapper">
    <div class="section__header-wrap flex lg:flex-col lg:justify-start justify-between">
      {% render 'section-heading',
        section_settings: section.settings,
        description: description,
        description_size: section.settings.text_size,
        button_visible: show_all_button_on_top,
        button_link: button_link,
        button_style: button_style,
        button_label: button_label
      %}
      {%- if enable_slider and header_layout == 'standing-column' -%}
        <div class="swiper-controls hidden md:flex items-center justify-start gap-2">
          <button class="swiper-button-prev btn" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
            {% render 'icon-slider-prev' %}
          </button>
          <button class="swiper-button-next btn" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
            {% render 'icon-slider-next' %}
          </button>
        </div>
      {%- endif -%}
    </div>

    <div class="section__content">
      <grid-list class="block relative swiper-show-nav-on-hover">
        <featured-collection
          class="block{% if enable_slider %} swiper f-grid--gap-{{ section.settings.column_gap }}{% endif %}{% if enable_swipe_mobile %} swipe-mobile swipe-mobile--{{ section.settings.columns_mobile }}-cols{% endif %}"
          data-section-id="{{ section.id }}"
          {% if enable_slider %}
            data-enable-slider="true"
            data-items="{{ columns_desktop }}"
            data-tablet-items="{{ columns_tablet }}"
            {% if header_layout == 'standing-column' %}
              data-calc-heading-column-height="true"
            {% else %}
              data-calc-button-position="true"
            {% endif %}
          {% endif %}
        >
          <div class="featured-collection__items products-list f-grid f-grid-{{ columns_mobile }}-cols md:f-grid-{{ columns_tablet }}-cols lg:f-grid-{{ columns_desktop }}-cols f-grid--gap-{{ section.settings.column_gap }} f-grid--row-gap-{{ section.settings.row_gap }}{% if enable_slider %} swiper-wrapper{% endif %}{% if enable_swipe_mobile %} swipe-mobile__inner{% endif %}">
            {%- for product in collection.products limit: products_to_display -%}
              <div class="{{ item_css_class }}">
                {%- if is_metro -%}
                  {%- capture card_metro -%}
                    {%- render 'card-product-metro',
                      product: product,
                      image_sizes: image_sizes,
                      image_ratio: section.settings.pcard_image_ratio,
                      section_index: section.index,
                      index: forloop.index,
                      index0: forloop.index0,
                      columns_desktop: columns_desktop,
                      columns_tablet: columns_tablet,
                      columns_mobile: columns_mobile
                    -%}
                  {%- endcapture -%}
                  {{ card_metro | replace: 'De ', '' }}
                {%- else -%}
                  {%- capture card_product -%}
                    {%- render 'card-product',
                      product: product,
                      image_sizes: image_sizes,
                      image_ratio: section.settings.pcard_image_ratio,
                      section_index: section.index,
                      index: forloop.index
                    -%}
                  {%- endcapture -%}
                  {{ card_product | replace: 'De ', '' }}
                {%- endif -%}
              </div>
            {%- else -%}
              {%- for i in (1..products_to_display) -%}
                <div class="{{ item_css_class }}">
                  {% render 'card-product-placeholder', image_ratio: section.settings.pcard_image_ratio %}
                </div>
              {%- endfor -%}
            {%- endfor %}
          </div>
        </featured-collection>

        {%- if enable_slider and header_layout != 'standing-column' -%}
          <div class="swiper-controls swiper-controls--{{ section.settings.controls_position }} hidden md:block">
            <button class="swiper-button-prev btn" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
              {% render 'icon-slider-prev' %}
            </button>
            <button class="swiper-button-next btn" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
              {% render 'icon-slider-next' %}
            </button>
          </div>
        {%- endif %}
      </grid-list>
    </div>
  </div>

  {%- if button_label != blank and show_all_button_on_top != true -%}
    <div class="section__footer flex items-center justify-center">
      <a class="btn {{ button_style }}" href="{{ button_link }}">{{ button_label }}</a>
    </div>
  {%- endif %}
</div>

<script src="{{ 'featured-collection.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Featured collection",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    { "type": "paragraph", "content": "[Read How-to](https://foxecom.link/qX0NYfg)" },
    { "type": "header", "content": "General" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Section header" },
    {
      "type": "select",
      "id": "header_layout",
      "label": "Layout",
      "options": [
        { "value": "vertical", "label": "Vertical" },
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "standing-column", "label": "Standing column" }
      ],
      "default": "vertical"
    },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Featured collection" },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h6", "label": "H6" },
        { "value": "h5", "label": "H5" },
        { "value": "h4", "label": "H4" },
        { "value": "h3", "label": "H3" },
        { "value": "h2", "label": "H2" },
        { "value": "h1", "label": "H1" },
        { "value": "hd3", "label": "HD3" },
        { "value": "hd2", "label": "HD2" },
        { "value": "hd1", "label": "HD1" }
      ]
    },
    { "type": "header", "content": "Highlight" },
    { "type": "paragraph", "content": "Highlight text settings" },
    {
      "type": "select",
      "id": "heading_highlight_style",
      "label": "Highlight",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "underline", "label": "Underline" }
      ]
    },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "richtext", "id": "description", "label": "Description" },
    {
      "type": "select",
      "id": "text_size",
      "label": "Description text size",
      "default": "text-base",
      "options": [
        { "value": "text-sm", "label": "Small" },
        { "value": "text-base", "label": "Base" },
        { "value": "text-lg", "label": "Large" },
        { "value": "text-inherit", "label": "Inherit" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "Use collection description",
      "default": false
    },
    { "type": "collection", "id": "collection", "label": "Collection" },

    { "type": "header", "content": "Grid" },
    {
      "type": "range",
      "id": "limit",
      "label": "Products limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "column_gap",
      "label": "Column gap",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "extra-small", "label": "Extra small" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "extra-large", "label": "Extra large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "row_gap",
      "label": "Row gap",
      "options": [
        { "value": "inherit", "label": "Inherit" },
        { "value": "none", "label": "None" },
        { "value": "extra-small", "label": "Extra small" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "extra-large", "label": "Extra large" }
      ],
      "default": "inherit"
    },

    {
      "type": "select",
      "id": "grid_layout",
      "label": "Grid layout",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "metro", "label": "Metro" }
      ],
      "default": "standard"
    },

    { "type": "header", "content": "Carousel" },
    { "type": "checkbox", "id": "enable_slider", "label": "Enable slider", "default": true },
    {
      "type": "select",
      "id": "controls_position",
      "label": "Controls position",
      "options": [
        { "value": "inside", "label": "Inside" },
        { "value": "outside", "label": "Outside" }
      ],
      "default": "inside"
    },

    { "type": "header", "content": "Product cards" },
    {
      "type": "select",
      "id": "pcard_image_ratio",
      "label": "Image ratio",
      "default": "",
      "options": [
        { "value": "", "label": "Adapt" },
        { "value": "1/1", "label": "1/1" },
        { "value": "3/4", "label": "3/4" },
        { "value": "4/3", "label": "4/3" }
      ]
    },

    { "type": "header", "content": "Mobile" },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    { "type": "checkbox", "id": "swipe_on_mobile", "label": "Enable swipe", "default": true },

    { "type": "header", "content": "View all button" },
    { "type": "checkbox", "id": "show_all_button_on_top", "label": "Show button on top", "default": false },
    { "type": "text", "id": "button_label", "label": "Button label" },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--underline", "label": "Underline" }
      ],
      "default": "btn--primary"
    },

    { "type": "header", "content": "Padding" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 50
    },

    { "type": "header", "content": "Divider" },
    { "type": "checkbox", "id": "show_section_divider", "label": "Show divider", "default": false },
    {
      "type": "select",
      "id": "divider_width",
      "label": "Divider width",
      "options": [
        { "value": "fixed", "label": "Fixed" },
        { "value": "full", "label": "Full" }
      ],
      "default": "fixed"
    },

    { "type": "header", "content": "Custom CSS class" },
    { "type": "text", "id": "custom_class", "label": "CSS class" }
  ],

  "presets": [
    { "name": "Featured collection" }
  ]
}
{% endschema %}