dido\n    <\/div>\n  <\/div>\n<\/div>\n\n<style>\n  .vv-delivery-note{\n    display:flex;\n    align-items:flex-start;\n    gap:10px;\n    width:100%;\n    padding:14px 16px;\n    border-radius:8px;\n    background:#e9f7ee;\n    color:#0b7a3a;\n  }\n\n  .vv-delivery-note__icon{\n    flex:0 0 auto;\n    width:18px;\n    height:18px;\n    border-radius:999px;\n    border:2px solid #16a34a;\n    color:#16a34a;\n    display:grid;\n    place-items:center;\n    font-weight:800;\n    font-size:12px;\n    line-height:1;\n    margin-top:2px;\n  }\n\n  .vv-delivery-note__text{\n    line-height:1.25;\n  }\n\n  .vv-delivery-note__title{\n    font-size:14px;\n    font-weight:600;\n  }\n\n  .vv-delivery-note__sub{\n    margin-top:4px;\n    font-size:13px;\n    font-weight:400;\n    opacity:.95;\n  }\n\n  @media (min-width: 990px){\n    .vv-delivery-note__title{font-size:15px}\n    .vv-delivery-note__sub{font-size:13.5px}\n  }\n<\/style>\n\n<script>\n(function(){\n\n  const startEl = document.getElementById('vv-delivery-start');\n  const endEl = document.getElementById('vv-delivery-end');\n\n  const monthNames = [\n    'jan.', 'fev.', 'mar.', 'abr.', 'maio', 'jun.',\n    'jul.', 'ago.', 'set.', 'out.', 'nov.', 'dez.'\n  ];\n\n  function addDays(date, days){\n    const result = new Date(date);\n    result.setDate(result.getDate() + days);\n    return result;\n  }\n\n  function formatDate(date){\n    const day = date.getDate();\n    const month = monthNames[date.getMonth()];\n    return day + ' de ' + month;\n  }\n\n  const today = new Date();\n\n  const minDate = addDays(today, 4);\n  const maxDate = addDays(today, 7);\n\n  startEl.textContent = formatDate(minDate);\n  endEl.textContent = formatDate(maxDate);\n\n})();\n<\/script>"}},"pickup_availability":{"type":"pickup_availability","settings":{}},"complementary":{"type":"complementary","settings":{"block_heading":"Pairs well with","make_collapsible_row":false,"icon":"tag","product_list_limit":4,"products_per_page":1,"image_ratio"