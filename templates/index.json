        "custom_liquid": "<div class=\"vv-banner-carousel\">\n  <div class=\"vv-banner-track\">\n    \n    <!-- SLIDE 1 - NOVO -->\n    <div class=\"vv-banner-slide active\">\n      <a href=\"https://www.vivabeauty.com.br/collections/kits-semana-da-mulher\">\n        <picture>\n          <!-- MOBILE -->\n          <source\n            srcset=\"https://cdn.shopify.com/s/files/1/0754/9019/7721/files/Banner_Semana_da_Mulher_-_Mobile_3.png?v=1773356593\"\n            media=\"(max-width: 768px)\"\n          >\n          <!-- DESKTOP -->\n          <img\n            src=\"https://cdn.shopify.com/s/files/1/0754/9019/7721/files/Banner_Semana_da_Mulher_-_Desktop_5.png?v=1773356773\"Mês Consumidor\"\n            class=\"vv-banner-img\"\n            loading=\"lazy\"\n          >\n        </picture>\n      </a>\n    </div>\n\n    <!-- SLIDE 2 - ANTIGO -->\n    <div class=\"vv-banner-slide\">\n      <a href=\"https://www.vivabeauty.com.br/products/skin-complex-plus\" class=\"vv-banner-link\">\n        <picture>\n          <!-- MOBILE -->\n          <source\n            srcset=\"https://cdn.shopify.com/s/files/1/0754/9019/7721/files/Viva_Beauty-Fullbanner_Mobile_1080x1350_d0d4d552-5886-4e7d-8508-902d97ba4c77.png?v=1772222683\"\n            media=\"(max-width: 768px)\"\n          >\n          <!-- DESKTOP -->\n          <img\n            src=\"https://cdn.shopify.com/s/files/1/0754/9019/7721/files/Viva_Beauty-Fullbanner_Desktop_1920x610_7bcb1a1b-6348-4f11-b404-6952b4335c55.png?v=1772222682\"\n            alt=\"Banner Promocional\"\n            class=\"vv-banner-img\"\n            loading=\"lazy\"\n          >\n        </picture>\n      </a>\n    </div>\n\n  </div>\n\n  <div class=\"vv-banner-dots\">\n    <button class=\"vv-banner-dot active\"></button>\n    <button class=\"vv-banner-dot\"></button>\n  </div>\n</div>\n\n<style>\n  .vv-banner-carousel{\n    position:relative;\n    width:100%;\n    overflow:hidden;\n  }\n\n  .vv-banner-track{\n    position:relative;\n    width:100%;\n  }\n\n  .vv-banner-slide{\n    display:none;\n    width:100%;\n  }\n\n  .vv-banner-slide.active{\n    display:block;\n  }\n\n  .vv-banner-link{\n    display:block;\n    width:100%;\n  }\n\n  .vv-banner-img{\n    width:100%;\n    height:auto;\n    display:block;\n    border-radius:0;\n  }\n\n  .shopify-section{\n    overflow:hidden;\n  }\n\n  .vv-banner-dots{\n    position:absolute;\n    left:50%;\n    bottom:14px;\n    transform:translateX(-50%);\n    display:flex;\n    gap:8px;\n    z-index:3;\n  }\n\n  .vv-banner-dot{\n    width:10px;\n    height:10px;\n    border-radius:50%;\n    border:none;\n    background:rgba(255,255,255,.5);\n    cursor:pointer;\n    padding:0;\n  }\n\n  .vv-banner-dot.active{\n    background:#fff;\n  }\n\n  @media (max-width:768px){\n    .vv-banner-img{\n      width:100%;\n      height:auto;\n    }\n  }\n</style>\n\n<script>\n  (function() {\n    const carousel = document.querySelector('.vv-banner-carousel');\n    if (!carousel) return;\n\n    const slides = carousel.querySelectorAll('.vv-banner-slide');\n    const dots = carousel.querySelectorAll('.vv-banner-dot');\n\n    let current = 0;\n    let autoPlay;\n\n    function showSlide(index) {\n      slides.forEach((slide, i) => {\n        slide.classList.toggle('active', i === index);\n      });\n\n      dots.forEach((dot, i) => {\n        dot.classList.toggle('active', i === index);\n      });\n\n      current = index;\n    }\n\n    function nextSlide() {\n      let next = current + 1;\n      if (next >= slides.length) next = 0;\n      showSlide(next);\n    }\n\n    function startAutoPlay() {\n      autoPlay = setInterval(nextSlide, 5000);\n    }\n\n    dots.forEach((dot, index) => {\n      dot.addEventListener('click', function() {\n        showSlide(index);\n      });\n    });\n\n    showSlide(0);\n    startAutoPlay();\n  })();\n</script>",
